{
  "expo": {
    "name": "EchoOwl",
    "slug": "echoowl-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.echoowl.mobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "App needs local network access",
        "NSBonjourServiceTypes": [
          "_http._tcp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.echoowl.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "echoowl",
    "plugins": [
      [
        "expo-router",
        {
          "origin": false
        }
      ],
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID."
        }
      ],
      "@clerk/expo",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "12d244f9-cc40-4414-a67d-666e8dae8d99"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "samp231004"
  }
}
